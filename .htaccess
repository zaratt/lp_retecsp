# ============================================================
# RETEC SP — .htaccess
# ============================================================

# --------------------------------------------------------------
# 1. COMPRESSÃO GZIP (mod_deflate)
# Reduz o tamanho de HTML, CSS e JS transferidos pela rede.
# --------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE font/woff2

    # Não comprimir arquivos já comprimidos
    SetEnvIfNoCase Request_URI \.(?:gz|br|woff2|webp|jpg|jpeg|png|gif|ico|mp4)$ no-gzip dont-vary
</IfModule>

# --------------------------------------------------------------
# 2. CACHE DO NAVEGADOR (mod_expires)
# Define por quanto tempo os recursos ficam salvos no browser.
# --------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML — sem cache longo (conteúdo muda)
    ExpiresByType text/html                         "access plus 1 hour"

    # CSS e JS — sem cache longo (no-cache via mod_headers abaixo)
    ExpiresByType text/css                          "access plus 0 seconds"
    ExpiresByType application/javascript            "access plus 0 seconds"

    # Imagens
    ExpiresByType image/webp                        "access plus 1 year"
    ExpiresByType image/png                         "access plus 1 year"
    ExpiresByType image/jpeg                        "access plus 1 year"
    ExpiresByType image/svg+xml                     "access plus 1 year"
    ExpiresByType image/x-icon                      "access plus 1 year"

    # Fontes
    ExpiresByType font/woff2                        "access plus 1 year"
    ExpiresByType font/woff                         "access plus 1 year"
</IfModule>

# --------------------------------------------------------------
# 3. CABEÇALHOS CACHE-CONTROL (complemento ao mod_expires)
# --------------------------------------------------------------
<IfModule mod_headers.c>
    # CSS e JS: sempre revalidar no servidor (nunca servir cache sem verificar)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "no-cache"
    </FilesMatch>

    # Imagens e fontes: cache imutável por 1 ano (conteúdo nunca muda)
    <FilesMatch "\.(webp|png|jpg|jpeg|svg|ico|woff2|woff)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML: revalidar a cada visita
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>

    # Segurança
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --------------------------------------------------------------
# 4. FORÇAR HTTPS (redirecionar HTTP → HTTPS)
# Descomente as linhas abaixo se o servidor tiver SSL ativo.
# --------------------------------------------------------------
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} off
#     RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# --------------------------------------------------------------
# 5. ETags — desativar para evitar duplicidade com Cache-Control
# --------------------------------------------------------------
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# --------------------------------------------------------------
# 6. URLs SEM EXTENSÃO .html
# --------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # URLs antigas com underscore → URLs com hífen (301 permanente)
    RewriteRule ^aluguel_cacamba_barueri(\.html)?$ /aluguel-cacamba-barueri [R=301,L]
    RewriteRule ^aluguel_cacamba_osasco(\.html)?$ /aluguel-cacamba-osasco [R=301,L]
    RewriteRule ^aluguel_cacamba_sao_paulo(\.html)?$ /aluguel-cacamba-sao-paulo [R=301,L]
    RewriteRule ^aluguel_cacamba_santana_parnaiba(\.html)?$ /aluguel-cacamba-santana-parnaiba [R=301,L]

    # Redirecionar .html → sem extensão
    RewriteRule ^areas-atendimento\.html$ /areas-atendimento [R=301,L]

    # Redireciona /pagina.html → /pagina (301 permanente para SEO)
    RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Internamente serve o arquivo .html correspondente
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]
</IfModule>
